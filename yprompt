                              bg-[var(--bg-base)]
                              text-xs font-semibold
                              text-[var(--text-primary)]
                              outline-none
                              cursor-pointer">
                       @for (c of countryCodes; track c.code) {
                         <option [value]="c.code">
                           {{ c.label }}
                         </option>
                       }
                     </select>
                   </div>

                   <!-- Phone number input -->
                   <input
                     type="tel"
                     [ngModel]="contactForm
                                .get('whatsappNumber')!
                                .value"
                     (ngModelChange)="contactForm
                       .get('whatsappNumber')!
                       .setValue($event)"
                     placeholder="9xxxxxxxxx"
                     maxlength="9"
                     class="flex-1 px-4 py-3
                            bg-transparent
                            text-sm font-semibold
                            text-[var(--text-primary)]
                            placeholder:text-[var(--text-muted)]
                            outline-none">
                 </div>

                 @if (contactForm.get('whatsappNumber')!
                      .invalid &&
                      contactForm.get('whatsappNumber')!
                      .touched) {
                   <p class="text-xs text-red-500
                              flex items-center gap-1">
                     <svg lucideAlertCircle
                          class="w-3 h-3">
                     </svg>
                     يرجى إدخال رقم صحيح (9 أرقام)
                   </p>
                 }

               </div>

               <!-- Divider -->
               <div class="h-px bg-[var(--border)]">
               </div>

               <!-- Passenger details — one per seat -->
               <div class="flex flex-col gap-5"
