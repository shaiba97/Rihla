                         border-l border-[var(--border)]
                         flex flex-col gap-6">

               <!-- Contact details -->
               <div class="flex flex-col gap-4">
                 <h3 class="text-sm font-bold
                            text-[var(--text-primary)]
                            flex items-center gap-2">
                   <svg lucideSmartphone
                        class="w-4 h-4
                               text-[var(--primary)]">
                   </svg>
                   بيانات التواصل
                 </h3>
                 <p class="text-xs
                           text-[var(--text-muted)] -mt-2">
                   سيتم إرسال التذكرة على هذا الرقم
                 </p>

                 <!-- WhatsApp field -->
                 <div class="flex gap-0 overflow-hidden
                             rounded-xl border
                             border-[var(--border)]
                             focus-within:border-[var(--primary)]
                             focus-within:ring-2
                             focus-within:ring-[var(--primary-light)]
                             transition-all duration-150
                             bg-[var(--bg-card)]">

                   <!-- Country code select -->
                   <div class="flex-shrink-0
