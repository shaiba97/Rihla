                 <h3 class="text-sm font-bold
                            text-[var(--text-primary)]
                            flex items-center gap-2">
                   <svg lucideUser
                        class="w-4 h-4
                               text-[var(--primary)]">
                   </svg>
                   بيانات الركاب
                 </h3>

                 <div formArrayName="passengers"
                      class="flex flex-col gap-4">
                   @for (p of passengersArray.controls;
                         track $index) {
                     <div [formGroupName]="$index"
                          class="flex flex-col gap-4
                                 p-4 rounded-2xl
                                 border border-[var(--border)]
                                 bg-[var(--bg-base)]">

                       <!-- Passenger header -->
                       <div class="flex items-center
                                   gap-2">
                         <div class="w-7 h-7 rounded-full
                                     bg-[var(--primary-light)]
                                     flex items-center
                                     justify-center
                                     flex-shrink-0">
                           <svg lucideUser
                                class="w-3.5 h-3.5
                                       text-[var(--primary)]">
                           </svg>
                         </div>
                         <span class="text-sm font-bold
                                      text-[var(--text-primary)]">
                           راكب {{ $index + 1 }}
                         </span>
                         <span class="text-xs
                                      text-[var(--text-muted)]
                                      mr-auto">
                           مقعد رقم
                           {{ selectedSeats()[$index] }}
                         </span>
                       </div>

                       <!-- Name -->
                       <input
                         type="text"
                         formControlName="name"
                         placeholder="الاسم الكامل"
                         class="w-full px-4 py-3
                                rounded-xl border
                                border-[var(--border)]
                                bg-[var(--bg-card)]
                                text-sm font-semibold
                                text-[var(--text-primary)]
                                placeholder:text-[var(--text-muted)]
                                placeholder:font-normal
                                outline-none
                                focus:border-[var(--primary)]
                                focus:ring-2
                                focus:ring-[var(--primary-light)]
                                transition-all duration-150">

                       <!-- Age -->
                       <input
                         type="number"
                         formControlName="age"
                         placeholder="العمر"
                         min="1"
                         max="120"
                         class="w-full px-4 py-3
                                rounded-xl border
                                border-[var(--border)]
                                bg-[var(--bg-card)]
                                text-sm font-semibold
                                text-[var(--text-primary)]
                                placeholder:text-[var(--text-muted)]
                                placeholder:font-normal
                                outline-none
                                focus:border-[var(--primary)]
                                focus:ring-2
                                focus:ring-[var(--primary-light)]
                                transition-all duration-150">

                       <!-- Gender -->
                       <div class="flex gap-3">
                         <label class="flex-1 flex
                                       items-center
                                       justify-center
                                       gap-2 py-3
                                       rounded-xl
                                       border-2
                                       cursor-pointer
                                       transition-all
                                       duration-150
                                       text-sm
                                       font-semibold"
                                [ngClass]="p.get('gender')!
                                  .value === 'MALE'
                                  ? ['border-[var(--primary)]',
                                     'bg-[var(--primary-light)]',
                                     'text-[var(--primary)]']
                                  : ['border-[var(--border)]',
                                     'bg-[var(--bg-card)]',
                                     'text-[var(--text-secondary)]']">
                           <input type="radio"
                                  formControlName="gender"
                                  value="MALE"
                                  class="hidden">
                           ذكر
                         </label>
                         <label class="flex-1 flex
                                       items-center
                                       justify-center
                                       gap-2 py-3
                                       rounded-xl
                                       border-2
                                       cursor-pointer
                                       transition-all
                                       duration-150
                                       text-sm
                                       font-semibold"
                                [ngClass]="p.get('gender')!
                                  .value === 'FEMALE'
                                  ? ['border-[var(--primary)]',
                                     'bg-[var(--primary-light)]',
                                     'text-[var(--primary)]']
                                  : ['border-[var(--border)]',
                                     'bg-[var(--bg-card)]',
                                     'text-[var(--text-secondary)]']">
                           <input type="radio"
                                  formControlName="gender"
                                  value="FEMALE"
                                  class="hidden">
                           أنثى
                         </label>
                       </div>

                     </div>
                   }
                 </div>
               </div>

               <!-- Continue button -->
               <button
                 (click)="goToStep('payment')"
                 [disabled]="!canGoToPayment()"
                 class="w-full flex items-center
                        justify-center gap-2
                        py-3 px-6 rounded-xl
                        text-sm font-bold text-white
                        bg-[var(--primary)]
                        hover:bg-[var(--primary-hover)]
                        disabled:opacity-40
                        disabled:cursor-not-allowed
                        transition-all duration-150
                        active:scale-95">
                 <span>المتابعة للدفع</span>
                 <svg lucideChevronLeft
                      class="w-4 h-4">
                 </svg>
               </button>

             </div>

             <!-- LEFT: Trip summary -->
             <div class="w-full lg:w-[320px]
                         flex-shrink-0 p-6
                         bg-[var(--bg-card)]
                         flex flex-col gap-5">

               <!-- Bus name -->
               <div class="flex items-center gap-3">
                 <div class="w-10 h-10 rounded-xl
                             bg-[var(--primary-light)]
                             flex items-center
                             justify-center">
                   <svg lucideBus
                        class="w-5 h-5
                               text-[var(--primary)]">
                   </svg>
                 </div>
                 <div>
                   <p class="text-sm font-bold
                              text-[var(--text-primary)]">
                     {{ tripDetails()!.busName }}
                   </p>
                 </div>
               </div>

               <div class="h-px bg-[var(--border)]">
               </div>

               <!-- Journey -->
               <div class="flex flex-col gap-3">
                 <div class="flex items-center gap-3">
                   <div class="w-2.5 h-2.5 rounded-full
                               bg-[var(--primary)]
                               flex-shrink-0">
                   </div>
                   <div>
                     <p class="text-xs font-bold
                                text-[var(--text-primary)]">
                       {{ tripDetails()!.tripTime
                          | timeFormat }}
                       — {{ tripDetails()!.boardingCity }}
                     </p>
                     <p class="text-[10px]
                                text-[var(--text-muted)]">
                       {{ tripDetails()!.boardingStation }}
                     </p>
                   </div>
                 </div>
                 <div class="flex items-center gap-3">
                   <div class="w-2.5 h-2.5 rounded-full
                               border-2
                               border-[var(--primary)]
                               flex-shrink-0">
                   </div>
                   <div>
                     <p class="text-xs font-bold
                                text-[var(--text-primary)]">
                       {{ tripDetails()!.arriveTime
                          | timeFormat }}
                       — {{ tripDetails()!.destCity }}
                     </p>
                     <p class="text-[10px]
                                text-[var(--text-muted)]">
                       {{ tripDetails()!.destStation }}
                     </p>
                   </div>
                 </div>
               </div>

               <!-- Seat details -->
               <div class="flex flex-col gap-2
                           p-3 rounded-xl
                           bg-[var(--bg-base)]
                           border border-[var(--border)]">
                 <p class="text-xs font-bold
                            text-[var(--text-primary)]">
                   تفاصيل المقاعد
                 </p>
                 <div class="flex flex-wrap gap-1.5">
                   @for (s of selectedSeats(); track s) {
                     <span class="px-2.5 py-1
                                  rounded-full text-xs
                                  font-bold
                                  bg-[var(--primary)]
                                  text-white">
                       {{ s }}
                     </span>
                   }
                 </div>
               </div>

               <!-- Total -->
               <div class="flex items-center
                           justify-between px-3 py-3
                           rounded-xl
                           bg-[var(--primary-light)]
                           border border-[var(--border)]">
                 <span class="text-sm font-bold
                              text-[var(--primary)]">
                   الإجمالي
                 </span>
                 <span class="text-lg font-extrabold
                              text-[var(--primary)]">
                   {{ totalPrice() }}
                   {{ currency() }}
                 </span>
               </div>

             </div>

           </div>
         }

         <!-- ════════════════════════════════════ -->
         <!-- TAB 3: PAYMENT                      -->
         <!-- ════════════════════════════════════ -->
         @if (currentStep() === 'payment') {
           <div class="flex flex-col lg:flex-row
                       gap-0 min-h-[500px]">

             <!-- RIGHT: Payment options -->
             <div class="flex-1 p-6
                         border-l border-[var(--border)]
                         flex flex-col gap-6">

               <h3 class="text-sm font-bold
                          text-[var(--text-primary)]
                          flex items-center gap-2">
                 <svg lucideCreditCard
                      class="w-4 h-4
                             text-[var(--primary)]">
                 </svg>
                 اختر طريقة الدفع
               </h3>

               <!-- Payment gateways grid -->
               <div class="grid grid-cols-2
                           sm:grid-cols-4 gap-3">
                 @for (gw of paymentGateways; track gw.id) {
                   <button
                     (click)="selectGateway(gw.id)"
                     class="flex flex-col items-center
                            justify-center gap-2
                            p-4 rounded-2xl border-2
                            transition-all duration-150
                            cursor-pointer
                            min-h-[100px]"
                     [ngClass]="selectedGateway() === gw.id
                       ? ['border-[var(--primary)]',
                          'bg-[var(--primary-light)]',
                          'shadow-md']
                       : ['border-[var(--border)]',
                          'bg-[var(--bg-card)]',
                          'hover:border-[var(--primary)]',
                          'hover:bg-[var(--primary-light)]']">

                     <!-- Gateway icon -->
                     <div class="w-12 h-12 rounded-xl
                                 flex items-center
                                 justify-center
                                 flex-shrink-0"
                          [ngClass]="selectedGateway()===gw.id
                            ? ['bg-[var(--primary)]']
                            : ['bg-[var(--bg-base)]']">
                       <svg [lucideIcon]="gw.icon"
                            class="w-6 h-6"
                            [ngClass]="selectedGateway()===gw.id
                              ? ['text-white']
                              : ['text-[var(--primary)]']">
                       </svg>
                     </div>

                     <!-- Gateway name -->
                     <span class="text-sm font-bold"
                           [ngClass]="selectedGateway()===gw.id
                             ? ['text-[var(--primary)]']
                             : ['text-[var(--text-primary)]']">
                       {{ gw.name }}
                     </span>

                     <!-- Selected indicator -->
                     @if (selectedGateway() === gw.id) {
                       <div class="w-5 h-5 rounded-full
                                   bg-[var(--primary)]
                                   flex items-center
                                   justify-center">
                         <svg lucideCheckCircle
                              class="w-3.5 h-3.5 text-white">
                         </svg>
                       </div>
                     }

                   </button>
                 }
               </div>

               <!-- Gateway instruction -->
               @if (selectedGateway()) {
                 <div class="p-4 rounded-2xl
                             bg-[var(--primary-light)]
                             border border-[var(--border)]
                             flex flex-col gap-2">
                   <p class="text-sm font-bold
                              text-[var(--primary)]">
                     تعليمات الدفع عبر
                     @switch (selectedGateway()) {
                       @case ('bankak') { بنكك }
                       @case ('fawry')  { فوري }
                       @case ('mashriq'){ المشرق }
                       @case ('bravo')  { برافو }
                     }
                   </p>
                   <p class="text-xs
                              text-[var(--text-secondary)]
                              leading-relaxed">
                     سيتم توجيهك لإتمام الدفع عبر
                     بوابة الدفع المختارة.
                     بعد التأكيد سيتم إنشاء تذكرتك
                     وإرسالها على رقم واتساب المسجل.
                   </p>
                 </div>
               }

               <!-- Error -->
               @if (error()) {
                 <div class="flex items-center gap-2
                             px-4 py-3 rounded-xl
                             bg-red-50
                             dark:bg-red-950/20
                             border border-red-200
                             text-red-600">
                   <svg lucideAlertCircle
                        class="w-4 h-4 flex-shrink-0">
                   </svg>
                   <span class="text-sm">
                     {{ error() }}
                   </span>
                 </div>
               }

               <!-- Submit button -->
               <button
                 (click)="onSubmit()"
                 [disabled]="!selectedGateway()
                             || isSubmitting()"
                 class="w-full flex items-center
                        justify-center gap-2
                        py-4 px-6 rounded-xl
                        text-sm font-bold text-white
                        bg-[var(--primary)]
                        hover:bg-[var(--primary-hover)]
                        disabled:opacity-40
                        disabled:cursor-not-allowed
                        transition-all duration-150
                        active:scale-95 mt-auto
                        shadow-lg">
                 @if (isSubmitting()) {
                   <svg lucideLoader
                        class="w-5 h-5 animate-spin">
                   </svg>
                   <span>جاري تأكيد الحجز...</span>
                 } @else {
                   <svg lucideCheckCircle
                        class="w-5 h-5">
                   </svg>
                   <span>تأكيد الحجز والدفع</span>
                 }
               </button>

             </div>

             <!-- LEFT: Booking summary -->
             <div class="w-full lg:w-[320px]
                         flex-shrink-0 p-6
                         bg-[var(--bg-card)]
                         flex flex-col gap-5">

